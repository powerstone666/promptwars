# Firebase Web SDK
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-web-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-firebase-app-id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your-google-analytics-measurement-id

# Google Maps / Places API
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# AI Provider (LiteLLM-compatible text/image path)
LITELLM_BASE_URL=https://your-litellm-compatible-endpoint.example.com
LITELLM_API_KEY=your-litellm-api-key
MODEL_NAME=your-text-image-model

# Voice Provider
DASHSCOPE_API_KEY=your-voice-provider-api-key
DASHSCOPE_COMPAT_API_URL=https://your-voice-provider-endpoint.example.com/v1/chat/completions
DASHSCOPE_VOICE_MODEL=your-voice-model

# Optional Gemini fallback
GEMINI_API_KEY=your-gemini-api-key
GEMINI_FALLBACK_MODEL=gemini-2.5-flash

# Optional Google Cloud / Cloud Run deployment context
# These are deployment-oriented placeholders, not required for local app runtime.
GOOGLE_CLOUD_PROJECT=your-google-cloud-project-id
GOOGLE_CLOUD_REGION=your-google-cloud-region
CLOUD_RUN_SERVICE=your-cloud-run-service-name
CLOUD_RUN_URL=https://your-cloud-run-service-url.a.run.app
GCLOUD_API_KEY=your-google-cloud-api-key

# App Config
APP_NAME=rakshak ai
MAX_INPUT_CHARS=4000
